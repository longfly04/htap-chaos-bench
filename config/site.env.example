# Copy this file to config/site.env and edit the values for your machine.
# This file is sourced automatically by config/project-paths.env when present.

# Host PostgreSQL binaries used by source runtime and by reload helpers that call psql directly.
SOURCE_PG_BINDIR=/home/sducs/postgresql-dev/install/17.4/bin

# External JOB benchmark checkout used for real JOB_DB_LOAD_POLICY=reload runs.
JOB_BENCHMARK_ROOT=/home/sducs/postgresql-dev/benchmarks/JOB-benchmark

# Relative paths inside JOB_BENCHMARK_ROOT.
# These defaults match the current gpu1 checkout under /home/sducs/postgresql-dev/benchmarks/JOB-benchmark.
JOB_IMPORT_SCHEMA_REL=import_imdb/schema.sql
JOB_IMPORT_LOAD_REL=import_imdb/load_sql.sql
JOB_IMPORT_FKINDEX_REL=import_imdb/fkindexes.sql
JOB_CSV_BASE_REL=import_imdb

# Placeholder root string expected inside load_sql.sql before rewrite.
# The current gpu1 load_sql.sql still points at the older datasets/ tree, so keep this value aligned with that source file.
JOB_IMPORT_LOAD_PLACEHOLDER_ROOT=/home/sducs/postgresql-dev/datasets/JOB-benchmark/import_imdb

# Optional source-runtime observability extension build/install settings.
# Enable only on machines where the PostgreSQL source/runtime is yours to modify.
INSTALL_OBSERVABILITY_EXTENSIONS=false
OBSERVABILITY_EXTENSION_SOURCE_ROOT=/home/sducs/postgresql-dev/extensions
OBSERVABILITY_EXTENSION_SOURCE_NAMES=pg_wait_sampling pgmeminfo system_stats pg_stat_kcache
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements,pg_wait_sampling,pg_stat_kcache

# Optional sysbench integration settings.
# Point SYSBENCH_BIN at a built sysbench binary when using JOB_TP_DRIVER=sysbench.
# SYSBENCH_SOURCE_ROOT can be used by local helper scripts if you add build automation later.
# SYSBENCH_BIN=/home/sducs/postgresql-dev/benchmarks/sysbench/src/sysbench
# SYSBENCH_SOURCE_ROOT=/home/sducs/postgresql-dev/benchmarks/sysbench
