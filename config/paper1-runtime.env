# Root-level defaults shared by paper1 manifests.
# shellcheck disable=SC1090
source "$CONFIG_ROOT/run-hooks.env"
SYSTEM="${SYSTEM:-pg-like}"
DATASET="${DATASET:-job}"
SEED="${SEED:-1}"
BUDGET_TIER="${BUDGET_TIER:-moderate}"
CACHE_MODE="${CACHE_MODE:-warm}"
OVERLAP="${OVERLAP:-tp-first}"
CHAOS_MODE="${CHAOS_MODE:-none}"
JOB_TP_DRIVER="${JOB_TP_DRIVER:-pgbench}"

LAB_ENV_FILE="${LAB_ENV_FILE:-pglab/compose/.env}"
LAB_RUNTIME_MODE="${LAB_RUNTIME_MODE:-container}"
MEMORY_PROFILE="${MEMORY_PROFILE:-default}"
BENCHMARK_DB_NAME="${BENCHMARK_DB_NAME:-job_first_imdb}"
JOB_DB_LOAD_POLICY="${JOB_DB_LOAD_POLICY:-reuse_if_present}"
APPLY_SQL_FILE="${APPLY_SQL_FILE:-$PROJECT_WORKSPACE_SQL_ROOT/observability/install_views.sql}"
RESET_STATS="${RESET_STATS:-true}"
EXPORT_PG_STATS="${EXPORT_PG_STATS:-true}"
OBSERVE_SAMPLING_INTERVAL_SECONDS="${OBSERVE_SAMPLING_INTERVAL_SECONDS:-5}"
OBSERVE_METRICS_PROFILE="${OBSERVE_METRICS_PROFILE:-mixed-default}"
OBSERVE_REQUIRED_EXTENSIONS="${OBSERVE_REQUIRED_EXTENSIONS:-pg_stat_statements,pg_buffercache,pg_wait_sampling,pg_stat_kcache,pgmeminfo,system_stats}"
OBSERVE_REQUIRED_PRELOAD_LIBRARIES="${OBSERVE_REQUIRED_PRELOAD_LIBRARIES:-pg_stat_statements,pg_wait_sampling,pg_stat_kcache}"
OBSERVE_REQUIRED_COMMANDS="${OBSERVE_REQUIRED_COMMANDS:-pg_activity}"
OBSERVE_PG_ACTIVITY_ENABLED="${OBSERVE_PG_ACTIVITY_ENABLED:-true}"
OBSERVE_PG_ACTIVITY_TIMEOUT_SECONDS="${OBSERVE_PG_ACTIVITY_TIMEOUT_SECONDS:-3}"
OBSERVE_PG_ACTIVITY_REFRESH_SECONDS="${OBSERVE_PG_ACTIVITY_REFRESH_SECONDS:-1}"
AUTO_RENDER_PLOTS="${AUTO_RENDER_PLOTS:-true}"
PLOT_PROFILE="${PLOT_PROFILE:-mixed-default}"
PLOT_DPI="${PLOT_DPI:-300}"
LOCK_OBSERVE_MODE="${LOCK_OBSERVE_MODE:-off}"
POSTGRES_SHARED_PRELOAD_LIBRARIES="${POSTGRES_SHARED_PRELOAD_LIBRARIES:-pg_stat_statements}"
INSTALL_OBSERVABILITY_EXTENSIONS="${INSTALL_OBSERVABILITY_EXTENSIONS:-false}"
WARMUP_SECONDS="${WARMUP_SECONDS:-10}"
MEASURE_SECONDS="${MEASURE_SECONDS:-60}"
DURATION_SECONDS="${DURATION_SECONDS:-60}"
EXPORT_RUN_ARTIFACTS="${EXPORT_RUN_ARTIFACTS:-true}"
