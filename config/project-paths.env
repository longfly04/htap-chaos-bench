# Derived project paths.
if [[ -z "${PROJECT_ROOT:-}" ]]; then
  _project_paths_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  PROJECT_ROOT="$(cd "$_project_paths_dir/.." && pwd)"
fi
CONFIG_ROOT="${CONFIG_ROOT:-$PROJECT_ROOT/config}"
EXP_ROOT="${EXP_ROOT:-$PROJECT_ROOT/exp}"
PROJECT_SCRIPTS_ROOT="${PROJECT_SCRIPTS_ROOT:-$PROJECT_ROOT/scripts}"
HARNESS_COMMON="${HARNESS_COMMON:-$PROJECT_SCRIPTS_ROOT/harness_common.sh}"
HARNESS_START="${HARNESS_START:-$PROJECT_SCRIPTS_ROOT/harness_start.sh}"
HARNESS_EXPORT_RUN_ARTIFACTS="${HARNESS_EXPORT_RUN_ARTIFACTS:-$PROJECT_SCRIPTS_ROOT/harness_export_run_artifacts.sh}"
HARNESS_EXPORT_PG_STATS="${HARNESS_EXPORT_PG_STATS:-$PROJECT_SCRIPTS_ROOT/harness_export_pg_stats.sh}"
HARNESS_SAMPLE_PG_STATS="${HARNESS_SAMPLE_PG_STATS:-$PROJECT_SCRIPTS_ROOT/harness_sample_pg_stats.sh}"
HARNESS_OBSERVE_LOCKS="${HARNESS_OBSERVE_LOCKS:-$PROJECT_SCRIPTS_ROOT/harness_observe_locks.sh}"
HARNESS_RESET_STATS="${HARNESS_RESET_STATS:-$PROJECT_SCRIPTS_ROOT/harness_reset_stats.sh}"
HARNESS_RUNTIME_LAUNCH="${HARNESS_RUNTIME_LAUNCH:-$PROJECT_SCRIPTS_ROOT/runtime_launch.sh}"
HARNESS_RUN_SLICE="${HARNESS_RUN_SLICE:-$PROJECT_SCRIPTS_ROOT/run_slice.sh}"
if [[ -n "${LAB_ROOT:-}" && "$PROJECT_ROOT" == "$LAB_ROOT"* ]]; then
  PROJECT_ROOT_REL="${PROJECT_ROOT#"$LAB_ROOT"}"
  PROJECT_ROOT_REL="${PROJECT_ROOT_REL#/}"
  if [[ -z "$PROJECT_ROOT_REL" ]]; then
    PROJECT_ROOT_REL="$(basename "$PROJECT_ROOT")"
  fi
  PROJECT_WORKSPACE_ROOT="${PROJECT_WORKSPACE_ROOT:-/workspace/$PROJECT_ROOT_REL}"
else
  PROJECT_ROOT_REL="${PROJECT_ROOT_REL:-$(basename "$PROJECT_ROOT")}"
  PROJECT_WORKSPACE_ROOT="${PROJECT_WORKSPACE_ROOT:-/workspace/$PROJECT_ROOT_REL}"
fi
PROJECT_WORKSPACE_SQL_ROOT="${PROJECT_WORKSPACE_SQL_ROOT:-$PROJECT_WORKSPACE_ROOT/exp/sql}"
DATASET_PACK_JOB="${DATASET_PACK_JOB:-$EXP_ROOT/datasets/job}"
SITE_ENV_FILE="${SITE_ENV_FILE:-$CONFIG_ROOT/site.env}"
if [[ -f "$SITE_ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$SITE_ENV_FILE"
fi
if [[ -z "${PYTHON_BIN:-}" ]]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN=python3
  else
    PYTHON_BIN=python
  fi
fi
export PYTHON_BIN
