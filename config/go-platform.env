# Defaults for Go-backed manifests.
# shellcheck disable=SC1090
source "$CONFIG_ROOT/run-hooks.env"
GO_PLATFORM_ROOT="${GO_PLATFORM_ROOT:-$PROJECT_ROOT}"
GO_PLATFORM_BIN="${GO_PLATFORM_BIN:-$PROJECT_ROOT/bin/htap-chaos-bench}"
ADAPTER="${ADAPTER:-postgres}"
VALIDATION_PROFILE="${VALIDATION_PROFILE:-paper1-default}"
POST_RUN_HOOK="${POST_RUN_HOOK:-$RUN_SCENARIO_HOOK}"
DATASET_PACK="${DATASET_PACK:-$DATASET_PACK_JOB}"
AP_PARALLELISM="${AP_PARALLELISM:-0}"
