PGLAB_BUILD_CONTEXT=/home/sducs/postgresql-dev
PGLAB_DOCKERFILE=exp/htap-chaos-bench/pglab/docker/Dockerfile.pgext
POSTGRES_BASE_IMAGE=docker.m.daocloud.io/library/postgres:17
POSTGRES_IMAGE=htapchaosbench-pgext:17
PG_MAJOR=17
COMPOSE_PROJECT_NAME=htapchaosbench-8u8g
DB_SERVICE_NAME=postgres
DB_HOST=127.0.0.1
DB_PORT=58438
DB_CONTAINER_USER=postgres
DB_CLIENT_BIN=psql
DB_NAME=benchdb
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=postgres
BENCH_USER=bench
BENCH_PASSWORD=bench_123
EXPORTER_USER=exporter
EXPORTER_PASSWORD=exporter_123
MEMORY_PROFILE=8u8g
CGROUP_CPU_LIMIT=8.0
CGROUP_MEMORY_LIMIT=8g
CGROUP_MEMORY_RESERVATION=6g
POSTGRES_SHARED_BUFFERS=2GB
POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=512MB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_DEFAULT_STATISTICS_TARGET=100
POSTGRES_RANDOM_PAGE_COST=4
POSTGRES_EFFECTIVE_IO_CONCURRENCY=2
POSTGRES_HUGE_PAGES=try
POSTGRES_JIT=off
POSTGRES_WAL_COMPRESSION=lz4
POSTGRES_AUTOVACUUM_MAX_WORKERS=4
POSTGRES_MIN_WAL_SIZE=1GB
POSTGRES_MAX_WAL_SIZE=4GB
POSTGRES_MAX_WORKER_PROCESSES=8
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=4
POSTGRES_MAX_PARALLEL_WORKERS=8
POSTGRES_MAX_PARALLEL_MAINTENANCE_WORKERS=4
POSTGRES_TEMP_FILE_LIMIT=-1
POSTGRES_MAX_CONNECTIONS=500
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements,pg_wait_sampling,pg_stat_kcache
OBSERVE_REQUIRED_EXTENSIONS=pg_stat_statements,pg_buffercache,pg_wait_sampling,pg_stat_kcache,pgmeminfo,system_stats
OBSERVE_REQUIRED_PRELOAD_LIBRARIES=pg_stat_statements,pg_wait_sampling,pg_stat_kcache
OBSERVE_REQUIRED_COMMANDS=pg_activity
OBSERVE_PG_ACTIVITY_ENABLED=true
OBSERVE_PG_ACTIVITY_TIMEOUT_SECONDS=3
OBSERVE_PG_ACTIVITY_REFRESH_SECONDS=1
JOB_WARMUP_SECONDS=120
JOB_DURATION_SECONDS=180
JOB_MEASURE_SECONDS=180
JOB_TP_THREADS_LOW=8
JOB_TP_THREADS_MEDIUM=16
JOB_TP_THREADS_HIGH=32
JOB_TP_TERMINALS=48
JOB_AP_TERMINALS=4
JOB_AP_PARALLELISM=4
AP_BURST_INTERVAL_SECONDS=2
